# CRM Swift � Environment Variables
# Copy to .env and fill in your values

# Server
APP_HOST=0.0.0.0
APP_PORT=8080

# Database
DATABASE_URL=postgres://crm_swift:crm_swift_pass@localhost:5432/crm_swift

# Cache
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change�hars
JWT_ACCESS_TOKEN_EXPIRY=3600
JWT_REFRESH_TOKEN_EXPIRY=2592000

# Rate Limiting
AUTH_RATE_LIMIT_PER_MINUTE=5
API_RATE_LIMIT_PER_MINUTE=20

# Cache TTLs (seconds)
SCORE_CACHE_TTL=300
LIST_CACHE_TTL=120
SESSION_CACHE_TTL=3600

# Database Pool
DB_MIN_CONNECTIONS=5
DB_MAX_CONNECTIONS=20

# Communication Providers (defaults per tenant — override via PATCH /api/comms/providers)
# Email: mailgun (api.mailgun.net) or stmp (SMTP.com)
# SMS: telnyx (api.telnyx.com)
# API keys stored per-tenant in tenants.settings->communications

# Logging
RUST_LOG=crm_swift=debug,info
